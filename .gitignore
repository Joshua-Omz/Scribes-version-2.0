# ── Go ────────────────────────────────────────────────────────────────────────
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# ── Flutter / Dart ────────────────────────────────────────────────────────────
# Flutter build output
client/build/
client/.dart_tool/
client/.flutter-plugins
client/.flutter-plugins-dependencies
client/.packages

# Dart pub cache
.pub-cache/
.pub/

# iOS/macOS/Android generated files
client/ios/Pods/
client/android/.gradle/
client/android/local.properties
client/android/captures/
client/ios/.symlinks/

# ── Secrets / Environment ────────────────────────────────────────────────────
.env

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
